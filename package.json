{
  "name": "nuxt-theme-builder",
  "version": "1.3.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{json,md,yaml,yml,css}\"",
    "format:check": "prettier --check \"**/*.{json,md,yaml,yml,css}\"",
    "typecheck": "nuxt typecheck",
    "knip": "knip",
    "analyze": "nuxt analyze",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:full": "playwright test --update-snapshots=missing",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:ci": "playwright test tests/e2e/smoke",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "workflow:quick": "pnpm lint:fix && pnpm format && pnpm typecheck",
    "workflow:full": "pnpm lint:fix && pnpm format && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@internationalized/date": "^3.12.1",
    "@nuxt/content": "^3.13.0",
    "@nuxt/scripts": "^0.13.4",
    "@nuxt/ui": "^4.7.0",
    "@nuxtjs/mdc": "^0.20.2",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia/nuxt": "^0.11.3",
    "@tiptap/extension-emoji": "^3.22.4",
    "@vercel/analytics": "^2.0.1",
    "@vueuse/nuxt": "^14.2.1",
    "ai": "^6.0.168",
    "better-sqlite3": "^12.9.0",
    "dompurify": "^3.4.1",
    "nuxt": "^4.4.2",
    "nuxt-og-image": "^5.1.13",
    "nuxt-schema-org": "^5.0.10",
    "nuxt-security": "^2.5.1",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwindcss": "^4.2.4",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@iconify-json/lucide": "^1.2.103",
    "@iconify-json/simple-icons": "^1.2.79",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.2",
    "@playwright/test": "^1.59.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "dotenv": "^17.4.2",
    "eslint": "9.28.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4"
    }
  }
}
